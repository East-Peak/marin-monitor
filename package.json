{
	"name": "marin-monitor",
	"version": "2.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"strava:explore": "node scripts/strava-explore.mjs",
		"strava:curate": "node scripts/strava-curate.mjs",
		"traffic:evaluate": "node scripts/evaluate-traffic-sources.mjs",
		"sync:police": "node scripts/extract-police-logs.mjs",
		"sync:activity": "node scripts/extract-activity-feeds.mjs",
		"sync:coffee-index": "node scripts/sync-coffee-index.mjs",
		"sync:install": "bash scripts/manage-sync.sh install",
		"sync:uninstall": "bash scripts/manage-sync.sh uninstall",
		"sync:status": "bash scripts/manage-sync.sh status",
		"coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.49.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@testing-library/svelte": "^5.0.0",
		"@types/d3": "^7.4.0",
		"@types/jsdom": "^28.0.0",
		"@types/node": "^22.0.0",
		"@types/react": "^19.2.14",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"@vitest/coverage-v8": "^4.1.9",
		"autoprefixer": "^10.4.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-svelte": "^2.0.0",
		"globals": "^15.0.0",
		"jsdom": "^25.0.0",
		"playwright": "^1.61.0",
		"postcss": "^8.4.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^3.0.0",
		"react": "^19.2.4",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.52.0",
		"vite": "^6.0.0",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@fontsource-variable/outfit": "^5.2.8",
		"@sparticuz/chromium": "^143.0.4",
		"@vercel/analytics": "^1.6.1",
		"@vercel/blob": "^2.3.2",
		"d3-scale": "^4.0.2",
		"d3-selection": "^3.0.0",
		"d3-shape": "^3.2.0",
		"linkedom": "^0.18.12",
		"maplibre-gl": "^4.7.1",
		"puppeteer-core": "^24.40.0"
	},
	"overrides": {
		"cookie": "0.7.2"
	}
}
