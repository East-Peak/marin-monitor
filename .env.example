# 511.org API token — get one at https://511.org/open-data/token
# Covers: Golden Gate Transit/Ferry, Marin Transit, SMART train
VITE_511_API_KEY=

# NPS API key — get one at https://www.nps.gov/subjects/developer/get-started.htm
# Covers: Park alerts for Point Reyes, Muir Woods, Golden Gate NRA
VITE_NPS_API_KEY=

# AirNow API key (optional) — get one at https://docs.airnowapi.org/account/request/
VITE_AIRNOW_API_KEY=

# TomTom Traffic API key (optional) — get one at https://developer.tomtom.com/
VITE_TOMTOM_API_KEY=

# Mapbox access token (optional) — get one at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=
