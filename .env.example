# Server-side API keys (NOT bundled into client code)

# 511.org API token — get one at https://511.org/open-data/token
# Used by /api/transit and /api/traffic/events
API_511_KEY=

# NPS API key — get one at https://www.nps.gov/subjects/developer/get-started.htm
# Used by /api/nps/alerts
NPS_API_KEY=

# AirNow API key — get one at https://docs.airnowapi.org/account/request/
# Used by /api/air-quality
AIRNOW_API_KEY=

# Client-side keys (public — bundled into browser code)

# Mapbox access token — get one at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=
